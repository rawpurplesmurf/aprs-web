# ─── Identity ───────────────────────────────────────────────────────────────
# Your callsign with SSID (e.g. W1AW-9)
MY_CALLSIGN=

# ─── Direwolf TNC ───────────────────────────────────────────────────────────
# Hostname or IP of the machine running Direwolf (DNS-resolvable on your LAN)
DIREWOLF_HOST=
# KISS TCP port (Direwolf default: 8001)
DIREWOLF_KISS_PORT=8001

# ─── Web Server ─────────────────────────────────────────────────────────────
WEB_PORT=3000

# ─── Beacon Settings ────────────────────────────────────────────────────────
# AX.25 digipeater path for outbound beacons (comma-separated)
BEACON_PATH=WIDE1-1,WIDE2-1
# APRS symbol table identifier  (/ = primary, \ = alternate)
BEACON_SYMBOL_TABLE=/
# APRS symbol code within the table (> = car, [ = jogger, - = house, etc.)
BEACON_SYMBOL_CODE=>
